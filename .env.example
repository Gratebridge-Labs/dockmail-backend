# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dockmail?schema=public

# Redis (Bull queue)
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SMTP outbound (Mailcow)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Mailcow API (provisioning)
MAILCOW_API_URL=
MAILCOW_API_KEY=
# "true" if HTTPS uses a self-signed cert (e.g. SSH tunnel to 127.0.0.1)
MAILCOW_TLS_INSECURE=

# App
APP_DOMAIN=dockmail.app
API_URL=
INBOUND_MX_HOST=mail.dockmail.app

# IMAP inbound sync (Mailcow/Dovecot; defaults host to INBOUND_MX_HOST)
# IMAP_HOST=
IMAP_PORT=993
# IMAP_TLS_INSECURE=true
# IMAP_SYNC_ENABLED=true
IMAP_INITIAL_SYNC_LIMIT=50

# Tracking (optional until API is deployed)
TRACKING_PIXEL_URL=
TRACKING_LINK_URL=

# DKIM selector used for DNS verification
DKIM_SELECTOR=dkim
# Optional: set this to your Mailcow DKIM public key so API returns exact DNS TXT record
# DKIM_PUBLIC_KEY=

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400
