# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dockmail?schema=public

# Redis (Bull queue)
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Amazon SES (outbound)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=

# Mailcow API (provisioning)
MAILCOW_API_URL=
MAILCOW_API_KEY=

# App
APP_DOMAIN=dockmail.app
API_URL=
INBOUND_MX_HOST=mail.dockmail.app

# Tracking (optional until API is deployed)
TRACKING_PIXEL_URL=
TRACKING_LINK_URL=

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400
